# ==================================================
# OMNISHIELD v4.0.0 - ENVIRONMENT CONFIGURATION
# ==================================================

# Application
ENVIRONMENT=development
PROJECT_NAME=OmniShield AI Moderation Platform
VERSION=4.0.0

# Security (CHANGE IN PRODUCTION!)
JWT_SECRET=super_secret_jwt_sign_key_change_me_in_production_1298471203
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql://postgres:1234@localhost:5432/moderation_db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Cache TTL (seconds)
IMAGE_CACHE_TTL=604800
API_RESPONSE_CACHE_TTL=300

# File Upload
MAX_FILE_SIZE_MB=10
MAX_BATCH_SIZE=100

# AI Models Configuration
ENABLE_NSFW_DETECTION=true
ENABLE_VIOLENCE_DETECTION=true
ENABLE_WEAPON_DETECTION=true
ENABLE_FACE_DETECTION=true
ENABLE_TEXT_MODERATION=true

# GPU Support
USE_GPU=false
GPU_DEVICE_ID=0

# Rate Limiting
DEFAULT_RATE_LIMIT_PER_MINUTE=60
ADMIN_RATE_LIMIT_PER_MINUTE=300

# CORS (comma-separated list)
CORS_ORIGINS=*

# OAuth2 (Optional - leave empty if not using)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloud Storage - Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 Storage (Optional alternative)
AWS_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=moderation-images

# Monitoring
ENABLE_PROMETHEUS_METRICS=true
SENTRY_DSN=

# ==================================================
# PRODUCTION CHECKLIST:
# ==================================================
# □ Generate strong JWT_SECRET: openssl rand -hex 32
# □ Change DATABASE_URL password
# □ Restrict CORS_ORIGINS to your domains
# □ Set ENVIRONMENT=production
# □ Configure OAuth2 credentials
# □ Set up Sentry DSN
# □ Configure S3 storage
# □ Enable GPU if available (USE_GPU=true)
# ==================================================
